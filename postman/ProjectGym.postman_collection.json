{
  "info": {
    "_postman_id": "b9a528e1-7e79-4d64-bca5-b82b9a7c36a4",
    "name": "ProjectGym API",
    "description": "Comprehensive Postman Collection for ProjectGym API. Covers Auth, Membership Plans, and Trainers endpoints. Auto-extracts Bearer Token on Login.",
